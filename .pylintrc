[MASTER]\n# Global (default) settings\nignore=CVS\n# Set the output format\n# format=text\n# Disable the message categories you don't want to see\ndisable=missing-docstring,invalid-name\n\n[FORMAT]\n# Maximum number of characters on a single line\nmax-line-length=120\n\n[MESSAGES CONTROL]\n# Enable specific message categories\nenable=all\n\n[DESIGN]\n# Maximum number of arguments for a function/method\nmax-args=5\n\n[IMPORTS]\n# Allow wildcard imports\nallow-wildcard-with-all=yes\n\n[LOGGING]\n# Logging levels to enable\nlogging-modules=logging,syslog\n\n[CLASSES]\n# Disable inheritance checks\ncheck-inheritance=false\n